# ===========================================
# AI Log Analyzer - Environment Configuration
# ===========================================
# Copy this file to .env and modify values

# === Database Configuration ===
POSTGRES_DB=ailoganalyzer
POSTGRES_USER=ailoguser
POSTGRES_PASSWORD=your_secure_password_here

CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your_clickhouse_password_here

# === Security ===
SECRET_KEY=your_secret_key_minimum_32_characters_here
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# === Admin Account ===
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin_password_change_on_first_login

# === Data Storage ===
DATA_DIR=/data
RAW_LOG_DIR=/data/raw
PARSED_LOG_DIR=/data/parsed
REPORT_DIR=/data/reports
AUDIT_DIR=/data/audit

# === CORS ===
CORS_ORIGINS=http://localhost,http://localhost:80

# === AI Providers (Optional defaults) ===
# Claude (Anthropic)
CLAUDE_API_KEY=
CLAUDE_API_URL=https://api.anthropic.com

# OpenAI
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=

# === Email Configuration ===
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# === Logging ===
LOG_LEVEL=INFO
LOG_FILE=/data/audit/app.log

# === Rate Limiting ===
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD_SECONDS=60